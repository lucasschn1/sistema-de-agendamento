{
  "name": "clinica/api",
  "description": "API de agendamento para clínica de psicologia",
  "type": "project",
  "php": ">=8.2",
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2",
    "vlucas/phpdotenv": "^5.6",
    "firebase/php-jwt": "^7.1",
    "resend/resend-php": "^1.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "test": "vendor/bin/phpunit --testdox",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
  }
}
